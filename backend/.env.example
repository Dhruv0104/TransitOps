# Server
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Neon / Postgres — app runtime (use pooled URL if Neon; hostname includes -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Prisma migrate needs a direct (non-pooler) URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# ---------------------------------------------------------------------------
# License email reminders (optional — without SMTP, emails are logged to console)
# ---------------------------------------------------------------------------

# Days before expiry to treat a license as "due for reminder" (default: 30)
LICENSE_REMINDER_DAYS=30

# Cron schedule for automatic reminders (server local time)
# Default: every day at 09:00 → 0 9 * * *
# Examples:
#   every day 09:00     → 0 9 * * *
#   every 6 hours       → 0 */6 * * *
#   disable cron        → off
LICENSE_REMINDER_CRON=0 9 * * *

# SMTP (required for real email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="TransitOps <your-email@gmail.com>"
