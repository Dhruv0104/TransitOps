# Server
PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Neon / Postgres — app runtime (use pooled URL if Neon; hostname includes -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Prisma migrate needs a direct (non-pooler) URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
